---
import CommitLog from '../components/commits/CommitLog.astro';
import Layout from '../layouts/Layout.astro';
import { fetchCommitFeed } from '../lib/commits';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { commits, source } = await fetchCommitFeed(100);

const sourceLabel =
  lang === 'zh-TW'
    ? source === 'git'
      ? '來自專案 git 紀錄'
      : source === 'cache'
        ? '來自 build 時快取的 commit feed'
        : source === 'github'
          ? '來自 GitHub commit feed'
          : '目前無法取得更新資料'
    : source === 'git'
      ? 'From local git history'
      : source === 'cache'
        ? 'From the build-time cached commit feed'
        : source === 'github'
          ? 'From the GitHub commit feed'
          : 'Updates are temporarily unavailable';
---

<Layout
  title={t('changelog.meta.title')}
  description={t('changelog.meta.description')}
  lang={lang}
>
  <div class="changelog-page">
    <header class="changelog-header">
      <h1>{t('changelog.header.title')}</h1>
      <p class="changelog-subtitle">
        {t('changelog.header.subtitle')}
      </p>
      <p class="changelog-meta">
        {lang === 'zh-TW' ? '共 ' : ''}{commits.length}{' '}
        {t('changelog.header.meta.updates')} · {sourceLabel} ·
        <a
          href="https://github.com/frank890417/taiwan-md/commits/main"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </p>
    </header>

    <CommitLog
      commits={commits}
      lang={lang}
      variant="timeline"
      locale={t('changelog.locale')}
      dayUpdatesLabel={t('changelog.day.updates')}
      emptyTitle={lang === 'zh-TW'
        ? '目前暫時抓不到更新紀錄'
        : 'Update history is temporarily unavailable'}
      emptyDescription={lang === 'zh-TW'
        ? '這頁現在會優先讀取 git，失敗時會退回 build-time 快取與 GitHub，避免部署後整頁空白。'
        : 'This page now prefers git, then falls back to a build-time cache and GitHub to avoid shipping an empty changelog.'}
      emptyLinkHref="https://github.com/frank890417/taiwan-md/commits/main"
      emptyLinkLabel="GitHub"
      relativeTimeLabels={{
        justNow: t('changelog.time.just-now'),
        minutesAgo: t('changelog.time.minutes-ago'),
        hoursAgo: t('changelog.time.hours-ago'),
        daysAgo: t('changelog.time.days-ago'),
      }}
    />
  </div>
</Layout>

<style>
  .changelog-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .changelog-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .changelog-header h1 {
    font-size: 2.5rem;
    font-weight: 900;
    color: #1a1a2e;
    margin-bottom: 0.75rem;
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    letter-spacing: 0.05em;
  }

  .changelog-subtitle {
    font-size: 1.15rem;
    color: #64748b;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .changelog-meta {
    font-size: 0.9rem;
    color: #94a3b8;
  }

  .changelog-meta a {
    color: #3b82f6;
    text-decoration: none;
  }

  .changelog-meta a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .changelog-page {
      padding: 3rem 1rem 4rem;
    }

    .changelog-header h1 {
      font-size: 2rem;
    }
  }
</style>
