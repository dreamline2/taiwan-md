---
import SemiontPageTemplate from '../../templates/semiont-page.template.astro';
import { loadSemiontPage } from '../../lib/semiont-page';

const page = await loadSemiontPage('DNA.md');
---

<SemiontPageTemplate
  title="品質基因"
  description="Taiwan.md 的遺傳密碼：品質基因、內容基因、骨骼基因、行為基因、Sonnet 反射——定義什麼是好文章、什麼是禁忌。"
  filename="DNA.md"
  subtitle="品質標準、反模式禁止清單、Sonnet 反射"
  html={page.html}
  headings={page.headings}
  wordCount={page.wordCount}
  emoji="🧬"
  breadcrumbLabel="dna"
/>
