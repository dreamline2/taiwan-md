---
/**
 * SupporterGrid.astro — About 頁面「💚 個人支持者」的 data-driven 卡片 grid
 *
 * 資料來源：public/api/about-supporters.json（由 scripts/core/generate-supporters-data.js 派生）
 * 顯示：按 tier（大樹/小樹/新芽）分組的卡片 grid + 對話泡泡留言
 * 隱私鐵律：不顯示金額 / email / gmail_message_id / 支持編號
 *
 * Tier 策略（2026-04-20 option C）：
 *   - 呈現「累計投入層級」而非單筆金額，避免一次性 vs 長期支持的金額比較
 *   - 閾值寫在 scripts/core/generate-supporters-data.js TIER_CONFIG，UI 跟著 JSON 走
 *
 * v1.1 | 2026-04-20
 */
import fs from 'node:fs';
import path from 'node:path';

const SUPPORTERS_PATH = path.join(
  process.cwd(),
  'public/api/about-supporters.json',
);

type Tier = {
  id: string;
  emoji: string;
  label: string;
  label_en: string;
};

type TierConfig = Tier & { desc: string };

type Supporter = {
  display_name: string;
  anonymous: boolean;
  first_date: string;
  last_date: string;
  transaction_count: number;
  active_monthly: boolean;
  messages: { date: string; text: string; type: 'monthly' | 'one-time' }[];
  tier: Tier | null;
};

type AboutData = {
  supporter_count: number;
  tier_counts: Record<string, number>;
  tier_config: TierConfig[];
  supporters: Supporter[];
};

let data: AboutData = {
  supporter_count: 0,
  tier_counts: {},
  tier_config: [],
  supporters: [],
};

try {
  data = JSON.parse(fs.readFileSync(SUPPORTERS_PATH, 'utf8'));
} catch {
  /* empty */
}

// Group supporters by tier (preserve tier_config order: canopy → grove → sprout)
const grouped = data.tier_config
  .map((cfg) => ({
    cfg,
    members: data.supporters.filter((s) => s.tier?.id === cfg.id),
  }))
  .filter((g) => g.members.length > 0);

function avatarUrl(s: Supporter): string {
  if (s.anonymous) {
    return `https://api.dicebear.com/9.x/shapes/svg?seed=anon-${encodeURIComponent(s.first_date + s.last_date)}&backgroundColor=e2e8f0,f1f5f9,d4d4d4`;
  }
  return `https://api.dicebear.com/9.x/initials/svg?seed=${encodeURIComponent(s.display_name)}&backgroundColor=a7c957,8fb85e,6fa28a&fontFamily=sans-serif`;
}
---

<div class="supporter-grid-wrapper">
  {
    data.supporters.length === 0 ? (
      <p class="supporter-empty">
        尚未收到公開顯示的個人支持 — 你可以成為第一位 ✨
      </p>
    ) : (
      <>
        <p class="supporter-tier-legend">
          {data.tier_config.map((cfg, i) => (
            <>
              {i > 0 && <span class="supporter-legend-sep">·</span>}
              <span class="supporter-legend-item">
                <span class="supporter-legend-emoji">{cfg.emoji}</span>
                {cfg.label}
                <span class="supporter-legend-desc">（{cfg.desc}）</span>
              </span>
            </>
          ))}
        </p>
        {grouped.map(({ cfg, members }) => (
          <section class="supporter-tier-section" data-tier={cfg.id}>
            <h4 class="supporter-tier-heading">
              <span class="supporter-tier-emoji">{cfg.emoji}</span>
              <span class="supporter-tier-name">{cfg.label}</span>
              <span class="supporter-tier-count">{members.length} 位</span>
            </h4>
            <ul class="supporter-grid" role="list">
              {members.map((s) => (
                <li class="supporter-card" data-anonymous={s.anonymous}>
                  <div class="supporter-avatar-wrap">
                    <img
                      class="supporter-avatar"
                      src={avatarUrl(s)}
                      alt={`${s.display_name} avatar`}
                      loading="lazy"
                      width="56"
                      height="56"
                    />
                    {s.active_monthly && (
                      <span
                        class="supporter-monthly-badge"
                        title="每月定額贊助者"
                        aria-label="每月定額贊助者"
                      >
                        ♻︎
                      </span>
                    )}
                  </div>
                  <div class="supporter-body">
                    <p class="supporter-name">
                      {s.display_name}
                      <span
                        class="supporter-tier-pill"
                        title={`${cfg.label} · ${cfg.desc}`}
                      >
                        {cfg.emoji}
                      </span>
                    </p>
                    {s.messages.length > 0 && (
                      <div class="supporter-messages">
                        {s.messages.map((m) => (
                          <blockquote class="supporter-bubble">
                            {m.text}
                          </blockquote>
                        ))}
                      </div>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </>
    )
  }
</div>

<style>
  .supporter-grid-wrapper {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .supporter-empty {
    color: #64748b;
    font-size: 0.95rem;
    font-style: italic;
    margin: 1rem 0;
  }
  .supporter-tier-legend {
    margin: 0 0 0.5rem;
    color: #64748b;
    font-size: 0.82rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: baseline;
  }
  .supporter-legend-item {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .supporter-legend-emoji {
    font-size: 1rem;
  }
  .supporter-legend-desc {
    color: #94a3b8;
  }
  .supporter-legend-sep {
    color: #cbd5e1;
  }

  .supporter-tier-section {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .supporter-tier-section[data-tier='canopy'] {
    --tier-accent: #5a8a3a;
    --tier-tint: #f3f7ed;
  }
  .supporter-tier-section[data-tier='grove'] {
    --tier-accent: #6fa28a;
    --tier-tint: #f1f7f4;
  }
  .supporter-tier-section[data-tier='sprout'] {
    --tier-accent: #94a3b8;
    --tier-tint: #f8fafc;
  }

  .supporter-tier-heading {
    margin: 0;
    padding: 0;
    font-size: 0.98rem;
    font-weight: 600;
    color: #0f172a;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .supporter-tier-emoji {
    font-size: 1.1rem;
  }
  .supporter-tier-name {
    color: var(--tier-accent);
  }
  .supporter-tier-count {
    color: #94a3b8;
    font-weight: 400;
    font-size: 0.85rem;
  }

  .supporter-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .supporter-card {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
    padding: 0.9rem;
    border: 1px solid #e2e8f0;
    border-left: 3px solid var(--tier-accent, #e2e8f0);
    border-radius: 10px;
    background: var(--tier-tint, #fdfdfc);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }
  .supporter-card:hover {
    box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
  }
  .supporter-card[data-anonymous='true'] {
    background: #fafafa;
  }
  .supporter-avatar-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .supporter-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: block;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
  }
  .supporter-monthly-badge {
    position: absolute;
    bottom: -4px;
    right: -4px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #a7c957;
    color: #ffffff;
    font-size: 0.75rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #ffffff;
    font-weight: 600;
  }
  .supporter-body {
    flex: 1;
    min-width: 0;
  }
  .supporter-name {
    margin: 0 0 0.4rem;
    font-weight: 600;
    font-size: 0.98rem;
    color: #0f172a;
    line-height: 1.3;
    word-break: break-word;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .supporter-tier-pill {
    font-size: 0.9rem;
    opacity: 0.75;
    cursor: help;
  }
  .supporter-messages {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .supporter-bubble {
    position: relative;
    margin: 0;
    padding: 0.55rem 0.75rem;
    background: rgba(255, 255, 255, 0.75);
    border-radius: 10px;
    border-top-left-radius: 2px;
    font-size: 0.88rem;
    line-height: 1.5;
    color: #334155;
    font-style: normal;
    border: none;
    quotes: none;
  }
  .supporter-bubble::before,
  .supporter-bubble::after {
    content: none;
  }
  .supporter-card[data-anonymous='true'] .supporter-bubble {
    background: rgba(255, 255, 255, 0.65);
    color: #475569;
  }
  @media (max-width: 640px) {
    .supporter-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
