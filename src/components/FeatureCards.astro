---
interface FeatureCard {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  lang?: 'zh-TW' | 'en';
  sectionTitle: string;
  cards: FeatureCard[];
}

const { lang = 'zh-TW', sectionTitle, cards } = Astro.props;

const isZh = lang === 'zh-TW';
---

<!--
  Phase 4 leaf migration #2: FeatureCards.astro
  ────────────────────────────────────────────
  - Scoped <style> block removed entirely
  - Replaced with Tailwind atomic utilities:
    - Section wrapper: my-20 mx-auto max-w-[1400px] px-8 (md:mx-5 md:my-14)
    - Section title: centered, font-bold 2.5rem (md: 2rem), cat-zh overrides family
    - 4-col grid → 2-col on md
    - Cards: white bg, rounded-xl, soft shadow, hover lift via pattern
    - Icons use drop-shadow filter to preserve the subtle depth

  Colors: #1f2937 (title ink), #6b7280 (muted body), #f1f5f9 / #e2e8f0
  (card borders) kept as arbitrary values because they're from a gray
  palette that doesn't match our ink tokens. Could be promoted to
  tokens in a later pass if reused.
-->
<section
  class:list={[
    'mx-auto my-20 max-w-[1400px] px-8 md:my-14 md:mx-5 md:px-0',
    { 'features--zh': isZh },
  ]}
>
  <h2
    class:list={[
      'mb-12 text-center text-[2.5rem] font-bold text-[#1f2937] md:mb-8 md:text-[2rem]',
      {
        "font-extrabold font-['jf-lanyanghei','Noto_Sans_TC','Source_Han_Sans_TC',sans-serif]":
          isZh,
      },
    ]}
  >
    {sectionTitle}
  </h2>
  <div
    class="mx-auto grid max-w-[1100px] grid-cols-4 gap-4 md:grid-cols-2 md:gap-5"
  >
    {
      cards.map((card) => (
        <div class="flex flex-col items-start gap-2 rounded-xl border border-[#f1f5f9] bg-white p-5 shadow-[0_2px_8px_rgba(0,0,0,0.04)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[#e2e8f0] hover:shadow-[0_8px_20px_rgba(0,0,0,0.08)] md:gap-4 md:p-6">
          <div class="flex-shrink-0 text-[2.5rem] leading-none [filter:drop-shadow(0_2px_4px_rgba(0,0,0,0.1))] md:text-[2.25rem]">
            {card.icon}
          </div>
          <div>
            <h3 class="mb-2 text-[1.15rem] font-semibold leading-tight text-[#1f2937] md:text-[1.1rem]">
              {card.title}
            </h3>
            <p class="m-0 text-[0.95rem] leading-relaxed text-[#6b7280] md:text-[0.9rem]">
              {card.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>
  <slot />
</section>
