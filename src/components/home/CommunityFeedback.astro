---
interface Props {
  feedbacks: { name: string; text: string }[];
}
const { feedbacks } = Astro.props;
const row1 = feedbacks.filter((_: any, i: number) => i % 3 === 0);
const row2 = feedbacks.filter((_: any, i: number) => i % 3 === 1);
const row3 = feedbacks.filter((_: any, i: number) => i % 3 === 2);

// Tailwind class strings for the repeating bubble + row tracks — extracted
// to variables so the loop stays readable.
const BUBBLE_CLS =
  "relative max-w-[360px] flex-shrink-0 rounded-2xl border border-white/10 bg-white/[0.08] px-[1.4rem] py-4 [backdrop-filter:blur(4px)] [&::after]:content-[''] [&::after]:absolute [&::after]:bottom-[-8px] [&::after]:left-6 [&::after]:h-0 [&::after]:w-0 [&::after]:border-l-[8px] [&::after]:border-r-[8px] [&::after]:border-t-[8px] [&::after]:border-l-transparent [&::after]:border-r-transparent [&::after]:border-t-[rgba(255,255,255,0.08)] max-[768px]:max-w-[280px] max-[768px]:rounded-xl max-[768px]:px-4 max-[768px]:py-3";
const TEXT_CLS =
  'text-[0.95rem] leading-[1.6] text-[#e2e8f0] max-[768px]:text-[0.85rem]';
const NAME_CLS =
  'mt-[0.6rem] text-[0.8rem] font-semibold text-[#7dd3fc] max-[768px]:text-[0.75rem]';
const ROW_CLS =
  'overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_5%,black_95%,transparent)] [-webkit-mask-image:linear-gradient(to_right,transparent,black_5%,black_95%,transparent)]';
const TRACK_LEFT =
  'flex w-max gap-[1.2rem] [animation:marquee-left_100s_linear_infinite]';
const TRACK_RIGHT =
  'flex w-max gap-[1.2rem] [animation:marquee-right_90s_linear_infinite]';
---

<!--
  Phase 7.6 — CommunityFeedback.astro (Tier 1 home component)
  Scoped <style> removed. The 2 marquee @keyframes moved to
  global.css so inline `[animation:marquee-left_...]` can resolve
  them. Long repeating class strings extracted as local const
  variables so the 3-row × 2-copy loop stays readable.
-->
<section
  class="overflow-hidden bg-[linear-gradient(135deg,#0f172a_0%,#1e293b_100%)] pb-12 pt-20 max-[768px]:pb-8 max-[768px]:pt-12"
  aria-labelledby="feedback-heading"
>
  <div class="mb-10 text-center">
    <h2
      id="feedback-heading"
      class="mb-2 font-['jf-lanyangming','Noto_Serif_TC','Source_Han_Serif_TC',serif] text-[2rem] font-light text-white max-[768px]:text-[1.5rem]"
    >
      來自社群的聲音
    </h2>
    <p class="text-[1.1rem] text-[#94a3b8]">真實使用者的回饋</p>
  </div>
  <div class="flex flex-col gap-[1.2rem]">
    <div class={ROW_CLS}>
      <div class={TRACK_LEFT}>
        {
          row1.map((f) => (
            <div class={BUBBLE_CLS}>
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
        {
          row1.map((f) => (
            <div class={BUBBLE_CLS} aria-hidden="true">
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
      </div>
    </div>
    <div class={ROW_CLS}>
      <div class={TRACK_RIGHT}>
        {
          row2.map((f) => (
            <div class={BUBBLE_CLS}>
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
        {
          row2.map((f) => (
            <div class={BUBBLE_CLS} aria-hidden="true">
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
      </div>
    </div>
    <div class={ROW_CLS}>
      <div class={TRACK_LEFT}>
        {
          row3.map((f) => (
            <div class={BUBBLE_CLS}>
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
        {
          row3.map((f) => (
            <div class={BUBBLE_CLS} aria-hidden="true">
              <div class={TEXT_CLS}>{f.text}</div>
              <div class={NAME_CLS}>{f.name}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
