---
/**
 * RelatedArticleCard — Premium card with cover image, category badge, title, description.
 * Used in the related articles grid below the article body.
 */

import { useTranslatedPath } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  title: string;
  slug: string;
  category: string;
  categoryName: string;
  categoryColor: string;
  categoryIcon?: string;
  description?: string;
  coverImage?: string;
  lang?: Locale;
}

const {
  title,
  slug,
  category,
  categoryName,
  categoryColor,
  categoryIcon,
  description,
  coverImage,
  lang = 'zh-TW',
} = Astro.props;

const translatePath = useTranslatedPath(lang);

const articleHref = translatePath(`/${category}/${slug}`);
const readMoreLabel = lang === 'en' ? 'Read article' : '閱讀全文';
---

<!--
  Phase 4 leaf migration #3: RelatedArticleCard.astro
  ───────────────────────────────────────────────────
  - Scoped <style> block removed entirely
  - All classes replaced with Tailwind atomic utilities
  - Uses group / group-hover: variants for parent-triggered child
    state changes (card-title color shift + card-cta gap-grow on hover)
  - Dynamic category colors still passed via inline style (they
    depend on categoryColor prop and change per card)
-->
<a
  href={articleHref}
  class="group flex flex-col overflow-hidden rounded-2xl border border-[rgba(26,60,52,0.07)] bg-white text-inherit no-underline shadow-[0_2px_12px_rgba(26,60,52,0.05)] transition-all duration-[250ms] hover:-translate-y-[5px] hover:shadow-[0_12px_40px_rgba(26,60,52,0.12)]"
  aria-label={title}
>
  <div
    class="relative h-40 overflow-hidden bg-[#e8efec] bg-cover bg-center"
    style={coverImage ? `background-image: url('${coverImage}')` : ''}
    aria-hidden="true"
  >
    {
      !coverImage && (
        <div
          class="absolute inset-0 flex items-center justify-center"
          style={`background: linear-gradient(135deg, ${categoryColor}22, ${categoryColor}44);`}
        >
          <span
            class="text-[2.8rem] leading-none opacity-75"
            style={`color: ${categoryColor};`}
          >
            {categoryIcon || title[0]}
          </span>
        </div>
      )
    }
    <div
      class="absolute inset-0 bg-gradient-to-b from-transparent from-40% to-[rgba(10,22,19,0.35)]"
      aria-hidden="true"
    >
    </div>
  </div>
  <div class="flex flex-1 flex-col gap-2 px-6 pb-6 pt-5">
    <span
      class="inline-block self-start rounded-full border border-solid px-[0.65rem] py-[0.22rem] font-['Inter',system-ui,sans-serif] text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
      style={`color: ${categoryColor}; background: ${categoryColor}14; border-color: ${categoryColor}28;`}
    >
      {categoryName}
    </span>
    <h3
      class="m-0 font-['Noto_Serif_TC',serif] text-base font-semibold leading-[1.45] text-[#1a3c34] transition-colors group-hover:text-[#006d77]"
    >
      {title}
    </h3>
    {
      description && (
        <p class="m-0 line-clamp-2 font-['Inter',system-ui,sans-serif] text-[0.8rem] leading-relaxed text-[#7a8b7e]">
          {description}
        </p>
      )
    }
    <span
      class="mt-auto inline-flex items-center gap-[0.3rem] pt-1 font-['Inter',system-ui,sans-serif] text-[0.78rem] font-semibold transition-[gap] duration-200 group-hover:gap-2"
      style={`color: ${categoryColor};`}
    >
      {readMoreLabel}
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
      >
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </span>
  </div>
</a>
